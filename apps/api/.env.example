# MySQL (local docker-compose) or Planetscale (staging/prod) — same driver.
DATABASE_URL="mysql://piramid:dev@localhost:3306/piramid"

JWT_SECRET="dev-only-secret-change-me"
JWT_EXPIRES_IN="7d"
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Optional — set these to wire the real Google OAuth flow (NextAuth on the
# web side exchanges the Google ID token against /auth/google here).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional observability.
SENTRY_DSN=
LOG_LEVEL=debug
